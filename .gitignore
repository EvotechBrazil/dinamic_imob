# ============================================================
# Dinamic Imobiliária — .gitignore
# ============================================================

# ----- Dependencies -----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ----- Build outputs -----
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# ----- Turbo -----
.turbo/

# ----- Testing -----
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# ----- Environment variables (NEVER COMMIT) -----
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test
!.env.example
!.env.*.example

# ----- Secrets -----
*.pem
*.key
*.crt
secrets/
.secrets

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- IDE / Editor -----
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ----- OS -----
.DS_Store
.AppleDouble
.LSOverride
ehthumbs.db

# ----- Prisma -----
prisma/migrations/dev.db*
prisma/*.db
prisma/*.db-journal

# ----- Docker -----
docker-compose.override.yml
.docker-data/

# ----- Storybook -----
storybook-static/

# ----- Sentry -----
.sentryclirc

# ----- Caches diversos -----
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ----- Uploads locais (dev) -----
uploads/
local-storage/

# ----- Vendor (references locais, NAO commitar) -----
vendor/

# ----- Caches de tools locais -----
.claude/
.playwright-mcp/

# ----- Screenshots de dev/debug na raiz -----
/dinamic-landing-full.png
/*-screenshot.png

# ----- Misc -----
*.local
.vercel
