# ============================================================
# Dinamic Imobiliária — Variáveis de ambiente
# ============================================================
# Copie este arquivo para .env.local (NUNCA commita)
# e preencha com seus valores reais.

# ----- Database (docker-compose local) -----
DATABASE_URL="postgresql://dinamic:dinamic@localhost:5432/dinamic?schema=public"
DATABASE_URL_DIRECT="postgresql://dinamic:dinamic@localhost:5432/dinamic?schema=public"

# ----- Redis (docker-compose local) -----
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ----- Meilisearch (docker-compose local) -----
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="masterKey-dev-only-replace-in-prod"

# ----- Auth (NextAuth) -----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com:-openssl-rand-base64-32"
JWT_SECRET="gere-com:-openssl-rand-base64-32"

# ----- OpenRouter (IA — substitui Anthropic direto) -----
# Get key em: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_DEFAULT_MODEL="qwen/qwen3.7-max"
OPENROUTER_PREMIUM_MODEL="qwen/qwen3.7-max"
OPENROUTER_APP_NAME="Dinamic Imobiliaria"
OPENROUTER_APP_URL="https://dinamicimoveis.com.br"

# ----- Storage (LocalStack S3 em dev, R2 em prod — adiado) -----
STORAGE_PROVIDER="local" # local | r2 | s3
STORAGE_LOCAL_PATH="./uploads"
# R2 (adiado pra entrega ao cliente)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="dinamic-photos"

# ----- Mapbox (chave pública — adiado, usa mock por hora) -----
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ----- WhatsApp Evolution API (adiado) -----
# EVOLUTION_API_URL=""
# EVOLUTION_API_KEY=""

# ----- Asaas (adiado — só stub no MVP) -----
# ASAAS_API_KEY=""
# ASAAS_BASE_URL="https://api-sandbox.asaas.com/v3"

# ----- D4Sign (adiado) -----
# D4SIGN_TOKEN_API=""
# D4SIGN_CRYPT_KEY=""

# ----- Observability (free tier, podem ficar vazios em dev) -----
SENTRY_DSN=""
POSTHOG_KEY=""
BETTERSTACK_TOKEN=""

# ----- App env -----
NODE_ENV="development"
PORT_WEB="3000"
PORT_API="3001"
PORT_WORKER="3002"
LOG_LEVEL="debug"
